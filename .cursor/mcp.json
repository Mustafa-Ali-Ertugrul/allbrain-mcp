{
  "mcpServers": {
    "allbrain": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        ".",
        "allbrain",
        "start",
        "--project",
        ".",
        "--agent",
        "cursor",
        "--db-path",
        ".allbrain.db"
      ],
      "cwd": ".",
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}
