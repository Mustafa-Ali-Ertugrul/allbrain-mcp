{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["Mustafa-Ali-Ertugrul"],
  "name": "AllBrain MCP",
  "description": "Event-sourced memory and orchestration server for multi-agent AI systems. Shared state, conflict resolution, deterministic replay, counterfactual reasoning, scenario planning, and foresight analysis for agent workflows.",
  "author": "Mustafa Ali Ertu\u011frul",
  "categories": [
    "agent-orchestration",
    "memory",
    "multi-agent",
    "event-sourcing",
    "workflow",
    "decision-analysis"
  ],
  "keywords": [
    "mcp",
    "agent",
    "multi-agent",
    "orchestration",
    "memory",
    "event-sourcing",
    "conflict-detection",
    "counterfactual",
    "scenario-planning",
    "foresight",
    "replay",
    "snapshot",
    "workflow",
    "ai-memory",
    "shared-state"
  ],
  "github": "https://github.com/Mustafa-Ali-Ertugrul/allbrain-mcp",
  "related_servers": [
    {
      "name": "Memory",
      "url": "https://glama.ai/mcp/servers/modelcontextprotocol/knowledge-graph-memory-server"
    },
    {
      "name": "Sequential Thinking",
      "url": "https://glama.ai/mcp/servers/%40new69toss/mcp-sequential-thinking"
    },
    {
      "name": "Context Manager",
      "url": "https://glama.ai/mcp/servers/transparentlyok/mcp-context-manager"
    }
  ],
  "runtime": {
    "type": "stdio",
    "command": "uv",
    "args": [
      "run",
      "allbrain",
      "start",
      "--project",
      ".",
      "--agent",
      "claude-code",
      "--tool-profile",
      "core"
    ],
    "env": {
      "ALLOWED_PROJECT_ROOTS": "/app"
    }
  },
  "config": {
    "timeout": 120000
  },
  "icon": "\ud83e\udde0"
}
